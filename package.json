  ],
  "scripts": {
    "prebuild": "pnpm gen-exports",
    "build": "vite build && tsc -p tsconfig.build.json",
    "dev": "vite",
    "demo": "vite --config demo/vite.config.js",
    "demo:build": "vite build --config demo/vite.config.js",
    "demo:preview": "vite preview --config demo/vite.config.js",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install chromium",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo '(no lint)'",
    "validate-meta": "tsx scripts/validate-meta.ts",
    "gen-exports": "tsx scripts/generate-exports.ts",
    "gen-registry": "tsx scripts/generate-registry.ts",
    "gen-skill": "tsx scripts/generate-skill.ts",
    "gen-skill:check": "tsx scripts/generate-skill.ts --check",
    "build-publish-manifest": "tsx scripts/build-publish-manifest.ts",
    "bundle-stats": "tsx scripts/bundle-stats.ts",
    "analyze": "ANALYZE=1 vite build && tsc -p tsconfig.build.json && pnpm bundle-stats",
    "check": "pnpm typecheck && pnpm validate-meta && pnpm gen-skill:check && pnpm test && pnpm build",
    "pack:inspect": "pnpm pack --pack-destination /tmp && echo '→ tarball at /tmp/custom-elements-collection-<version>.tgz'",
    "prepublishOnly": "pnpm gen-exports && pnpm build-publish-manifest --apply"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@types/node": "22.8.6",
    "jsdom": "25.0.1",
    "lit": "3.2.1",
    "rollup-plugin-visualizer": "7.0.1",
    "tsx": "4.19.2",
    "typescript": "5.9.3",
    "vite": "5.4.10",
    "vitest": "2.1.4",
    "zod": "3.23.8"
  },
