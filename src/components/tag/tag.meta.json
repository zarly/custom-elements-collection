{
  "schemaVersion": 2,
  "tag": "ce-tag",
  "name": "Tag",
  "className": "CeTag",
  "goal": "Render a content-taxonomy label — a topic, facet, or category — with an optional remove affordance.",
  "description": "Distinct from ce-chip (which is a status pip): ce-tag is a content-categorisation token used for tag clouds, multi-select filter facets, and topical labels. Leads with a faded # glyph for visual recognition. Seven CecColor tints (neutral default), and an optional × button that emits ce-tag-remove with the optional value identifier in the event detail. The label itself is slotted (vocabulary lives in children per CDR-001).",
  "stability": "stable",
  "created": "2026-04-29",
  "updated": "2026-05-26",
  "props": [
    {
      "name": "color",
      "type": "CecColor | null",
      "required": false,
      "default": "null",
      "reflect": true,
      "description": "Tag tint (neutral default when null)."
    },
    {
      "name": "removable",
      "type": "boolean",
      "required": false,
      "default": "false",
      "reflect": true,
      "description": "Show a × button that emits ce-tag-remove on click."
    },
    {
      "name": "value",
      "type": "string | null",
      "required": false,
      "default": "null",
      "description": "Opaque identifier surfaced in the ce-tag-remove event detail."
    }
  ],
  "events": [
    {
      "name": "ce-tag-remove",
      "detail": "{ value: string | null }",
      "bubbles": true,
      "composed": true,
      "description": "Fires when the user activates the × remove button."
    }
  ],
  "slots": [
    {
      "name": "",
      "description": "Tag label content."
    }
  ],
