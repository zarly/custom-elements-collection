{
  "schemaVersion": 2,
  "tag": "ce-tool-call",
  "name": "Tool call",
  "className": "CeToolCall",
  "goal": "Render an LLM/agent tool invocation as a collapsible row with a status indicator, name, duration, and slotted args/result/error panels.",
  "description": "Disclosure widget purpose-built for function-calling and MCP-call visibility. The header shows a status dot (running pulses; ok/error are static), the tool name in monospace, and a humanized duration. Clicking toggles a body panel that always renders args, plus result (status=ok) or error (status=error). Implements the disclosure semantics manually (header has aria-expanded + aria-controls) rather than wrapping native <details>, so styling is consistent across browsers.",
  "stability": "stable",
  "created": "2026-04-29",
  "updated": "2026-05-26",
  "props": [
    {
      "name": "name",
      "type": "string",
      "required": false,
      "default": "\"\"",
      "description": "Tool/function name shown in the header."
    },
    {
      "name": "status",
      "type": "\"running\" | \"ok\" | \"error\"",
      "required": false,
      "default": "\"running\"",
      "reflect": true,
      "description": "Current execution state; drives the dot color and which body slot renders."
    },
    {
      "name": "durationMs",
      "type": "number",
      "required": false,
      "default": "NaN",
      "attribute": "duration-ms",
      "description": "Wall-clock duration in milliseconds; omitted when not finite."
    },
    {
      "name": "open",
      "type": "boolean",
      "required": false,
      "default": "false",
      "reflect": true,
      "description": "Disclosure state. Reflected so consumers can style or query collapsed state."
    }
  ],
  "events": [
    {
      "name": "ce-toolcall-toggle",
      "detail": "{ open: boolean }",
      "bubbles": true,
      "composed": true,
      "description": "Fires after the user toggles the disclosure; detail carries the new open state."
    }
  ],
  "slots": [
    {
      "name": "args",
      "description": "Input arguments payload — always rendered when the panel is open."
    },
    {
      "name": "result",
      "description": "Return value — rendered when status=ok."
    },
    {
      "name": "error",
      "description": "Error details — rendered when status=error."
    }
  ],
  "cssVariables": [
    {
      "name": "--ce-surface",
      "kind": "color",
      "source": "token",
      "description": "Outer background."
    },
    {
      "name": "--ce-border",
      "kind": "color",
      "source": "token",
      "description": "Outer border."
    },
    {
