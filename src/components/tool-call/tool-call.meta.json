      "kind": "color",
      "source": "token",
      "description": "Header text."
    },
    {
      "name": "--ce-muted",
      "kind": "color",
      "source": "token",
      "description": "Chevron and duration."
    },
    {
      "name": "--ce-state-hover",
      "kind": "color",
