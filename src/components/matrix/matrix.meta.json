{
  "schemaVersion": 2,
  "tag": "ce-matrix",
  "name": "Matrix",
  "className": "CeMatrix",
  "goal": "Render a 2×2 quadrant chart (priority / Eisenhower / impact-effort) with axis labels, quadrant captions, and items placed per quadrant.",
  "description": "Decision-analysis primitive that fills the gap between ce-heatmap (cells of values) and ce-pros-cons (two columns). Axes are configurable (defaults: x=Effort, y=Impact) with low/high markers; the four quadrants carry default captions (Quick wins / Big bets / Fill-ins / Money pits) overridable via the q-labels JSON array. Each quadrant is tinted with a different semantic colour so the placement reads at a glance. Items are placed via either a JSON `items` array with explicit quadrant 0..3 or slotted children carrying `data-quadrant=\"0..3\"` (CDR-005 dual mode). Quadrant order is reading-order: 0=TL, 1=TR, 2=BL, 3=BR.",
  "stability": "stable",
  "created": "2026-05-20",
  "updated": "2026-05-26",
  "props": [
    {
      "name": "items",
      "type": "MatrixItem[]",
      "required": false,
      "default": "[]",
      "description": "JSON array of { label, quadrant: 0|1|2|3, hint? }. When empty, slotted children are used."
    },
    {
      "name": "xLabel",
      "type": "string",
      "required": false,
      "default": "\"Effort\"",
      "attribute": "x-label",
      "description": "Bottom axis label."
    },
    {
      "name": "yLabel",
      "type": "string",
      "required": false,
      "default": "\"Impact\"",
      "attribute": "y-label",
      "description": "Left axis label."
    },
    {
      "name": "xLow",
      "type": "string",
      "required": false,
      "default": "\"Low\"",
      "attribute": "x-low",
      "description": "Left x-axis marker."
    },
    {
      "name": "xHigh",
      "type": "string",
      "required": false,
      "default": "\"High\"",
      "attribute": "x-high",
      "description": "Right x-axis marker."
    },
    {
      "name": "yLow",
      "type": "string",
      "required": false,
      "default": "\"Low\"",
      "attribute": "y-low",
      "description": "Bottom y-axis marker."
    },
    {
      "name": "yHigh",
      "type": "string",
      "required": false,
      "default": "\"High\"",
      "attribute": "y-high",
      "description": "Top y-axis marker."
    },
    {
      "name": "qLabels",
      "type": "string[]",
      "required": false,
      "default": "[\"Quick wins\",\"Big bets\",\"Fill-ins\",\"Money pits\"]",
      "attribute": "q-labels",
      "description": "JSON array of 4 quadrant captions, in reading order (TL, TR, BL, BR)."
    }
  ],
  "events": [],
  "slots": [
    {
      "name": "",
      "description": "Slotted children carrying `data-quadrant=\"0..3\"` are routed into the matching quadrant cell."
    }
  ],
