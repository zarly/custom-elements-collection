{
  "schemaVersion": 2,
  "tag": "ce-pagination",
  "name": "Pagination",
  "className": "CePagination",
  "goal": "Render a page-navigation strip with first / prev / numbered / next / last controls and emit a ce-pagechange event.",
  "description": "Static-by-default page navigation: renders the current state from page + total, emits ce-pagechange on activation, and only mutates page itself when manage='self' is set (CDR-004 stateful opt-in). The numbered range collapses with ellipses when there are gaps, controlled by the sibling count. A compact mode swaps the number buttons for a 'n / total' info line for tight surfaces.",
  "stability": "stable",
  "created": "2026-05-20",
  "updated": "2026-05-26",
  "props": [
    {
      "name": "page",
      "type": "number",
      "required": false,
      "default": "1",
      "description": "Current page (1-indexed). Clamped to [1, total]."
    },
    {
      "name": "total",
      "type": "number",
      "required": false,
      "default": "1",
      "description": "Total number of pages."
    },
    {
      "name": "sibling",
      "type": "number",
      "required": false,
      "default": "1",
      "description": "Numeric siblings shown around the current page before ellipses kick in."
    },
    {
      "name": "manage",
      "type": "\"external\" | \"self\"",
      "required": false,
      "default": "\"external\"",
      "description": "'external' (default) leaves page mutation to the parent; 'self' updates page on click."
    },
    {
      "name": "compact",
      "type": "boolean",
      "required": false,
      "default": "false",
      "reflect": true,
      "description": "Hides number buttons; shows only first/prev/info/next/last."
    }
  ],
  "events": [
    {
      "name": "ce-pagechange",
      "detail": "{ page: number }",
      "bubbles": true,
      "composed": true,
      "description": "Fired when the user activates a page control. Detail.page is the clamped target page."
    }
  ],
  "slots": [],
  "cssVariables": [
    {
      "name": "--ce-text",
      "kind": "color",
      "source": "token",
      "description": "Default button text."
    },
    {
      "name": "--ce-text-inverse",
      "kind": "color",
      "source": "token",
      "description": "Active button text."
    },
    {
