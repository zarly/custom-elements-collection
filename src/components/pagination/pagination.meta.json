  "a11y": {
    "role": "navigation",
    "notes": "Wrapped in <nav aria-label='Pagination'>. Each numbered button carries an aria-label, the current page is marked with aria-current='page'. Compact info uses aria-live='polite' so screen readers announce page changes."
  },
