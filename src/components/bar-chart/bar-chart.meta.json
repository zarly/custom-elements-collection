{
  "schemaVersion": 1,
  "tag": "ce-bar-chart",
  "name": "BarChart",
  "className": "CeBarChart",
  "goal": "Render a minimal horizontal bar chart from a JSON array of { label, value, meta?, color? } rows.",
  "description": "Data-driven horizontal bar chart. Takes a data array as a JS property or JSON attribute, auto-scales to the largest value when max is unset, and supports per-row color overrides. Each row exposes ARIA progressbar semantics for accessibility.",
  "stability": "stable",
  "props": [
    {
      "name": "data",
      "type": "BarRow[]",
      "required": false,
      "default": "[]",
      "description": "Array of { label, value, meta?, color? }."
    },
    {
      "name": "max",
      "type": "number",
      "required": false,
      "default": "0",
      "description": "Forces chart maximum; 0 means auto-scale to the largest row value."
    },
    {
      "name": "color",
      "type": "CecColor",
      "required": false,
      "default": "\"blue\"",
      "reflect": true,
      "description": "Default bar color when a row has no color override."
    },
    {
      "name": "labelWidth",
      "type": "string",
      "required": false,
      "default": "\"180px\"",
      "attribute": "label-width",
      "description": "CSS width for the left label column."
    },
    {
      "name": "compact",
      "type": "boolean",
      "required": false,
      "default": "false",
      "reflect": true,
      "description": "Tighter rows + thinner bars."
    }
  ],
  "events": [],
  "slots": [],
  "cssVariables": [
    {
      "name": "--ce-space-3",
      "kind": "size",
      "source": "token",
      "description": "Row inner gap."
    },
    {
      "name": "--ce-space-2",
      "kind": "size",
      "source": "token",
      "description": "Row vertical margin + bar inner padding."
    },
    {
      "name": "--ce-bar-label-width",
      "kind": "size",
      "source": "local",
      "description": "Width of the left label column; set inline from labelWidth.",
      "fallback": "180px"
    },
    {
      "name": "--ce-muted",
      "kind": "color",
      "source": "token",
      "description": "Label + meta text color."
    },
    {
      "name": "--ce-text-sm",
      "kind": "size",
      "source": "token",
      "description": "Label font size."
    },
    {
      "name": "--ce-surface-2",
      "kind": "color",
      "source": "token",
      "description": "Track background."
    },
    {
      "name": "--ce-color-blue",
      "kind": "color",
      "source": "token",
      "description": "Default fill."
    },
    {
      "name": "--ce-text",
      "kind": "color",
      "source": "token",
      "description": "Bar inline value color."
    },
    {
      "name": "--ce-text-xs",
      "kind": "size",
      "source": "token",
      "description": "Bar inline value + meta font size."
    },
    {
      "name": "--ce-transition",
      "kind": "other",
      "source": "token",
      "description": "Width transition."
    },
    {
      "name": "--ce-color-green",
      "kind": "color",
      "source": "token",
      "description": "Per-row green fill."
    },
    {
      "name": "--ce-color-red",
      "kind": "color",
      "source": "token",
      "description": "Per-row red fill."
    },
    {
      "name": "--ce-color-amber",
      "kind": "color",
      "source": "token",
      "description": "Per-row amber fill."
    },
    {
      "name": "--ce-color-purple",
      "kind": "color",
      "source": "token",
      "description": "Per-row purple fill."
    },
    {
      "name": "--ce-color-cyan",
      "kind": "color",
      "source": "token",
      "description": "Per-row cyan fill."
    }
  ],
  "globalDependencies": [],
  "sideEffects": [],
  "dependents": [],
  "dependencies": [],
  "related": [
    "ce-chart"
  ],
  "category": "ui",
  "tier": "widget",
  "tags": [
    "Metrics & charts",
    "chart",
    "bars",
    "data-viz"
  ],
  "a11y": {
    "role": "progressbar (per row)",
    "notes": "Each bar exposes role=progressbar with aria-valuemin/max/now and an aria-label of the row label."
  }
}
