{
  "schemaVersion": 1,
  "tag": "ce-compare",
  "name": "Compare",
  "className": "CeCompare",
  "goal": "Display two slotted columns side by side as a Before/After (or A/B) panel separated by a configurable arrow.",
  "description": "Side-by-side comparison panel. Left column gets a red tint (Before), right column a green tint (After), and a center column shows a configurable arrow (default → ). Below 640px the layout collapses to a single column and the arrow hides.",
  "stability": "stable",
  "props": [
    {
      "name": "beforeLabel",
      "type": "string",
      "required": false,
      "default": "\"Before\"",
      "attribute": "before-label",
      "description": "Label above the left panel."
    },
    {
      "name": "afterLabel",
      "type": "string",
      "required": false,
      "default": "\"After\"",
      "attribute": "after-label",
      "description": "Label above the right panel."
    },
    {
      "name": "arrow",
      "type": "string",
      "required": false,
      "default": "\"→\"",
      "description": "Separator glyph; empty string hides the column."
    }
  ],
  "events": [],
  "slots": [
    {
      "name": "before",
      "description": "Left panel content."
    },
    {
      "name": "after",
      "description": "Right panel content."
    }
  ],
