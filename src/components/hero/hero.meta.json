{
  "schemaVersion": 1,
  "tag": "ce-hero",
  "name": "Hero",
  "className": "CeHero",
  "goal": "Render a page-opening header block with a kicker, title, lede, and an optional inline stats row.",
  "description": "Page header with eyebrow kicker, gradient-clipped title, lede paragraph, and a stats slot for inline KPIs. Provides a radial-gradient background by default; flat attribute suppresses it.",
  "stability": "stable",
  "created": "2026-04-29",
  "updated": "2026-05-21",
  "props": [
    {
      "name": "kicker",
      "type": "string",
      "required": false,
      "default": "\"\"",
      "description": "Eyebrow text shown above the title."
    },
    {
      "name": "title",
      "type": "string",
      "required": false,
      "default": "\"\"",
      "description": "Main heading text. Use the title slot to override with custom markup."
    },
    {
      "name": "lede",
      "type": "string",
      "required": false,
      "default": "\"\"",
      "description": "Supporting paragraph below the title."
    },
    {
      "name": "flat",
      "type": "boolean",
      "required": false,
      "default": "false",
      "reflect": true,
      "description": "Suppresses the radial-gradient background; uses the flat surface token instead."
    }
  ],
  "events": [],
