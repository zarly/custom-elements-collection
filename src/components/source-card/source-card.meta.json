{
  "schemaVersion": 1,
  "tag": "ce-source-card",
  "name": "Source card",
  "className": "CeSourceCard",
  "goal": "Render a single retrieved source for RAG / agent surfaces with title, site label, snippet, optional index and relevance score.",
  "description": "Panel companion to ce-citation. While ce-citation lives inline inside prose, ce-source-card is the list / sidebar artefact answering 'what did the model retrieve'. Wraps the title in <a target=_blank> when url is set, derives the site label from the URL host when site is omitted, and renders a relevance score normalising both 0..1 and 0..100 inputs to a percent display. Snippet text goes in the default slot; an optional [n] index threads into inline citations.",
  "stability": "stable",
  "created": "2026-05-20",
  "updated": "2026-05-21",
  "props": [
    {
      "name": "url",
      "type": "string",
      "required": false,
      "default": "\"\"",
      "description": "Link target. Wraps the title in an anchor opening in a new tab when set."
    },
    {
      "name": "title",
      "type": "string",
      "required": false,
      "default": "\"\"",
      "description": "Primary heading. Falls back to slotted title content."
    },
    {
      "name": "site",
      "type": "string",
      "required": false,
      "default": "\"\"",
      "description": "Display label for the source (host, publisher, repo). Falls back to the URL host."
    },
    {
      "name": "icon",
      "type": "string",
      "required": false,
      "default": "\"\"",
      "description": "Optional emoji or icon glyph rendered before the site label."
    },
    {
      "name": "score",
      "type": "number",
      "required": false,
      "default": "NaN",
      "description": "Relevance score. Accepts 0..1 or 0..100; rendered as a small percent pill."
    },
    {
      "name": "index",
      "type": "number",
      "required": false,
      "default": "NaN",
      "description": "Ordinal position rendered as [n]; wires the panel card to inline ce-citation references."
    }
  ],
  "events": [],
  "slots": [
    {
      "name": "title",
      "description": "Rich title markup; overrides the title attribute when present."
    },
    {
      "name": "",
      "description": "Snippet / preview text."
    },
    {
      "name": "meta",
      "description": "Extra inline metadata (date, author) next to the site label."
    },
    {
      "name": "footer",
      "description": "Footer actions or secondary controls."
    }
  ],
