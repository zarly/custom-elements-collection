{
  "schemaVersion": 1,
  "tag": "ce-details",
  "name": "Details",
  "className": "CeDetails",
  "goal": "Provide a styled, animated collapsible disclosure with a summary row and optional count chip.",
  "description": "Thin wrapper over native <details> with chevron rotation, hover state, an optional right-aligned count chip, and a custom toggle event. Reflects open to the host attribute so consumers can style or query collapsed state.",
  "stability": "stable",
  "created": "2026-04-29",
  "updated": "2026-05-21",
  "props": [
    {
      "name": "summary",
      "type": "string",
      "required": false,
      "default": "\"\"",
      "description": "Summary row text. Use the summary slot for custom markup."
    },
    {
      "name": "open",
      "type": "boolean",
      "required": false,
      "default": "false",
      "reflect": true,
      "description": "Whether the panel is expanded."
    },
    {
      "name": "count",
      "type": "string",
      "required": false,
      "default": "\"\"",
      "description": "Optional right-aligned count chip in the summary row."
    }
  ],
  "events": [
    {
      "name": "ce-details-toggle",
      "detail": "{ open: boolean }",
      "bubbles": true,
      "composed": true,
      "description": "Fires when the consumer toggles the disclosure; detail mirrors the new open state."
    }
  ],
  "slots": [
    {
      "name": "summary",
      "description": "Custom summary markup; overrides the summary attribute."
    },
    {
      "name": "",
      "description": "Body content shown when open."
    }
  ],
  "cssVariables": [
    {
