{
  "schemaVersion": 1,
  "tag": "ce-confirm",
  "name": "Confirm",
  "className": "CeConfirm",
  "goal": "Render an inline yes/no confirmation prompt with explicit confirm and cancel buttons.",
  "description": "Lightweight confirmation row used in place of an OS-level confirm dialog. Two buttons with semantic primary/secondary styling; danger variant tints the surface and primary button. Emits ce-confirm or ce-cancel; the host has role=alertdialog with the prompt as aria-label.",
  "stability": "stable",
  "created": "2026-05-05",
  "updated": "2026-05-21",
  "props": [
    {
      "name": "prompt",
      "type": "string",
      "required": false,
      "default": "\"Are you sure?\"",
      "description": "Question presented to the user (overridable via the `prompt` slot)."
    },
    {
      "name": "confirmLabel",
      "type": "string",
      "required": false,
      "default": "\"Confirm\"",
      "attribute": "confirm-label",
      "description": "Primary button label."
    },
    {
      "name": "cancelLabel",
      "type": "string",
      "required": false,
      "default": "\"Cancel\"",
      "attribute": "cancel-label",
      "description": "Secondary button label."
    },
    {
      "name": "variant",
      "type": "\"default\" | \"danger\"",
      "required": false,
      "default": "\"default\"",
      "reflect": true,
      "description": "Visual variant; danger tints surface + primary button."
    }
  ],
  "events": [
    {
      "name": "ce-confirm",
      "detail": "void",
      "bubbles": true,
      "composed": true,
      "description": "User confirmed."
    },
    {
      "name": "ce-cancel",
      "detail": "void",
      "bubbles": true,
      "composed": true,
      "description": "User cancelled."
    }
  ],
  "slots": [
    {
      "name": "prompt",
      "description": "Override the prompt attribute with arbitrary HTML."
    }
  ],
  "cssVariables": [
    {
