{
  "schemaVersion": 1,
  "tag": "ce-timeline",
  "name": "Timeline",
  "className": "CeTimeline",
  "goal": "Render a vertical or horizontal timeline of titled events from a JSON items array.",
  "description": "Timeline of TimelineItem entries. Each item has a title, optional meta line (date/duration/owner), optional description, optional color for the dot, and optional icon character. Vertical (default) renders a connecting rail; horizontal renders a row of equally-sized columns.",
  "stability": "stable",
  "props": [
    {
      "name": "items",
      "type": "TimelineItem[]",
      "required": false,
      "default": "[]",
      "description": "Array of { title, meta?, description?, color?, icon? }."
    },
    {
      "name": "orientation",
      "type": "\"vertical\" | \"horizontal\"",
      "required": false,
      "default": "\"vertical\"",
      "reflect": true,
      "description": "Layout axis."
    }
  ],
