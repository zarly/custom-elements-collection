{
  "schemaVersion": 1,
  "tag": "ce-persona",
  "name": "Persona",
  "className": "CePersona",
  "goal": "Display a user-research persona card with avatar, name, role, identity pills, detail paragraph, and metadata rows.",
  "description": "Persona / role card. Top row shows an emoji-or-character avatar plus name + role; optional `rank` and `score` attributes render as small pills beside the name. Below the head sits a `tags` slot for chips, a `detail` slot for a rich description paragraph, a `meta` slot for `<ce-kv>` metadata rows, and a default slot for arbitrary body content. Six color tints set the top border and avatar/pill tint.",
  "stability": "stable",
  "created": "2026-04-29",
  "updated": "2026-05-21",
  "props": [
    {
      "name": "name",
      "type": "string",
      "required": false,
      "default": "\"\"",
      "description": "Persona name."
    },
    {
      "name": "role",
      "type": "string",
      "required": false,
      "default": "\"\"",
      "description": "Role / title subtitle."
    },
    {
      "name": "avatar",
      "type": "string",
      "required": false,
      "default": "\"\"",
      "description": "Emoji or single character used as the avatar."
    },
    {
      "name": "color",
      "type": "CecColor",
      "required": false,
      "default": "\"neutral\"",
      "reflect": true,
      "description": "Top-border + avatar tint."
    },
    {
      "name": "rank",
      "type": "string",
      "required": false,
      "default": "\"\"",
      "description": "Short identity pill label shown beside the name (e.g. \"#1\", \"Top\"). Tinted by color."
    },
    {
      "name": "score",
      "type": "string",
      "required": false,
      "default": "\"\"",
      "description": "Short identity pill label shown beside the name (e.g. \"8 / 10\"). Tinted by color."
    }
  ],
  "events": [],
  "slots": [
    {
      "name": "tags",
      "description": "Optional chip row below the role."
    },
    {
      "name": "detail",
      "description": "Rich detail paragraph. Accepts `<p>`, `<a>`, `<ce-chip>`, or inline content."
    },
    {
      "name": "meta",
      "description": "Free-form metadata rows. Typically contains `<ce-kv slot=\"meta\" key=\"...\">value</ce-kv>` items."
    },
    {
      "name": "",
      "description": "Body content (typically a <dl> of attributes or legacy detail list)."
    }
  ],
