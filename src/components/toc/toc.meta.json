{
  "schemaVersion": 1,
  "tag": "ce-toc",
  "name": "Toc",
  "className": "CeToc",
  "goal": "Render a flat or numbered table of contents from a JSON entries array (or slotted anchors) with optional sticky positioning.",
  "description": "Table of contents component. Accepts an entries array of { href, label } via property or JSON attribute; optionally numbers each entry and sticks to the top of its scroll parent. When entries is empty, falls back to the default slot so consumers can supply <a> children directly.",
  "stability": "stable",
  "created": "2026-04-29",
  "updated": "2026-05-21",
  "props": [
    {
      "name": "entries",
      "type": "TocEntry[]",
      "required": false,
      "default": "[]",
      "description": "List of { href, label } items. Settable as a JS property or via JSON-encoded attribute."
    },
    {
      "name": "sticky",
      "type": "boolean",
      "required": false,
      "default": "false",
      "reflect": true,
      "description": "Use position: sticky at the top of the scroll container."
    },
    {
      "name": "numbered",
      "type": "boolean",
      "required": false,
      "default": "false",
      "reflect": true,
      "description": "Render as an <ol> with monospace tabular counters."
    }
  ],
  "events": [],
  "slots": [
    {
      "name": "",
      "description": "Fallback when entries is empty — consumer-supplied list/anchor markup."
    }
  ],
