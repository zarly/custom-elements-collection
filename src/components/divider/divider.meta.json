{
  "schemaVersion": 2,
  "tag": "ce-divider",
  "name": "Divider",
  "className": "CeDivider",
  "goal": "Render a themed 1px separator, optionally with a centered inline label, in either horizontal or vertical orientation.",
  "description": "Lightweight separator primitive. With no slotted content the rule is a continuous 1px line; with a slotted label the rule splits into two equal segments framing the label. Vertical orientation switches to a 1px inline column suitable for separating inline groups. The inset attribute pulls the rule away from container edges (none / sm / md / lg). Reads as role=separator to assistive tech.",
  "stability": "stable",
  "created": "2026-05-21",
  "updated": "2026-05-26",
  "props": [
    {
      "name": "orientation",
      "type": "\"horizontal\" | \"vertical\"",
      "required": false,
      "default": "\"horizontal\"",
      "reflect": true,
      "description": "Rule direction."
    },
    {
      "name": "inset",
      "type": "\"none\" | \"sm\" | \"md\" | \"lg\"",
      "required": false,
      "default": "\"none\"",
      "reflect": true,
      "description": "Horizontal padding applied to the rule so it pulls away from container edges."
    }
  ],
  "events": [],
  "slots": [
    {
      "name": "",
      "description": "Optional inline label centered between the two line segments."
    }
  ],
  "cssVariables": [
    {
