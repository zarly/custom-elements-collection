      "kind": "color",
      "source": "token",
      "description": "Rule color."
    },
    {
      "name": "--ce-muted",
      "kind": "color",
      "source": "token",
      "description": "Label text color."
    },
    {
      "name": "--ce-text-sm",
      "kind": "size",
      "source": "token",
      "description": "Label font size."
    },
    {
      "name": "--ce-space-2",
      "kind": "size",
      "source": "token",
      "description": "Gap between line and label."
    },
    {
      "name": "--ce-space-3",
      "kind": "size",
      "source": "token",
      "description": "Default vertical spacing around the rule + inset=sm horizontal padding."
    },
    {
      "name": "--ce-space-5",
      "kind": "size",
      "source": "token",
      "description": "inset=md horizontal padding."
    },
    {
      "name": "--ce-space-7",
      "kind": "size",
      "source": "token",
      "description": "inset=lg horizontal padding."
    }
  ],
