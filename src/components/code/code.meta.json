      "api": "navigator.clipboard.writeText",
      "purpose": "Primary copy path on the copy button.",
      "writes": true
    },
    {
      "api": "document.execCommand(\"copy\")",
      "purpose": "Fallback copy path when navigator.clipboard is unavailable; uses a transient hidden textarea.",
      "writes": true
    }
  ],
  "sideEffects": [
    {
      "kind": "dom",
      "description": "When the clipboard API is unavailable, creates and immediately removes a hidden textarea on document.body to invoke the legacy copy command.",
      "reason": "Maintains copy support in non-secure contexts where navigator.clipboard is absent."
    }
  ],
