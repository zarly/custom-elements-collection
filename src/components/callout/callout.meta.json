  "tag": "ce-callout",
  "name": "Callout",
  "className": "CeCallout",
  "goal": "Highlight short admonition text (info / success / warn / danger / neutral) with a left-border accent and tinted background.",
  "description": "Tinted left-border admonition box. Replaces drift between callout / admonition / alert / note / risk markup. Five semantic types color-code the border and background; an optional title overrides via attribute or named slot.",
