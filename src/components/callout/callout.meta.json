    {
      "name": "type",
      "type": "CalloutType",
      "required": false,
      "default": "\"info\"",
      "reflect": true,
      "description": "Color tone: info / success / warn / danger / neutral."
    },
    {
      "name": "title",
      "type": "string",
      "required": false,
      "default": "\"\"",
      "description": "Optional bold title row. Use the title slot for custom markup."
    }
  ],
