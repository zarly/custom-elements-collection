{
  "schemaVersion": 1,
  "tag": "ce-flow",
  "name": "Flow",
  "className": "CeFlow",
  "goal": "Render a horizontal or vertical step flow diagram from a JSON array of { title, caption?, color? } steps.",
  "description": "Step-flow diagram. Boxes separated by arrows; each step can have a caption and a color tint. Vertical attribute stacks boxes top-to-bottom and switches the default arrow from → to ↓ (consumers can override with the arrow attribute).",
  "stability": "stable",
  "props": [
    {
      "name": "steps",
      "type": "FlowStep[]",
      "required": false,
      "default": "[]",
      "description": "Array of { title, caption?, color? } steps."
    },
    {
      "name": "arrow",
      "type": "string",
      "required": false,
      "default": "\"→\"",
      "description": "Separator glyph between steps."
    },
    {
      "name": "vertical",
      "type": "boolean",
      "required": false,
      "default": "false",
      "reflect": true,
      "description": "Stack steps vertically with the down-arrow default."
    }
  ],
