{
  "schemaVersion": 1,
  "tag": "ce-flow",
  "name": "Flow",
  "className": "CeFlow",
  "goal": "Render a horizontal or vertical step flow diagram from either a JSON array of steps (steps prop) or from <ce-flow-step> slot children (CDR-005 dual mode).",
  "description": "Step-flow diagram. Boxes separated by arrows; each step can have a caption, step number (n), icon, and a color tint. Vertical attribute stacks boxes top-to-bottom and switches the default arrow from → to ↓. Accepts both JSON mode (steps prop) and slot mode (<ce-flow-step> children); JSON takes priority when non-empty (CDR-005).",
  "stability": "stable",
  "created": "2026-04-29",
  "updated": "2026-05-21",
  "props": [
    {
      "name": "steps",
      "type": "FlowStep[]",
      "required": false,
      "default": "[]",
      "description": "Array of { title, caption?, color?, n?, icon? } steps. When non-empty, takes priority over slot children (CDR-005 resolution order)."
    },
    {
      "name": "arrow",
      "type": "string",
      "required": false,
      "default": "\"→\"",
      "description": "Separator glyph between steps."
    },
    {
      "name": "vertical",
      "type": "boolean",
      "required": false,
      "default": "false",
      "reflect": true,
      "description": "Stack steps vertically with the down-arrow default."
    }
  ],
  "events": [],
  "slots": [
    {
      "name": "",
      "description": "Slot mode (CDR-005): place <ce-flow-step> children here. When steps prop is empty, the component iterates these children and renders them through the same pipeline as JSON mode. Non-ce-flow-step children are gracefully ignored (CDR-006)."
    }
  ],
