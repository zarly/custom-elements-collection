{
  "schemaVersion": 2,
  "tag": "ce-theme-switcher",
  "name": "ThemeSwitcher",
  "className": "CeThemeSwitcher",
  "goal": "Cycle / select from a named list of values via an arrow-button + dropdown control, emitting ce-change on selection.",
  "description": "Compact cycler + dropdown. Layout: ‹ [ Current Label ▾ ] ›. Left/right arrows step through options; the label toggles a grouped dropdown; ArrowLeft/Right and Escape are handled inside the widget. The component is generic — it does not itself touch document themes; consumers wire the ce-change event to whatever they want updated.",
  "stability": "stable",
  "created": "2026-04-29",
  "updated": "2026-05-26",
  "props": [
    {
      "name": "value",
      "type": "string",
      "required": false,
      "default": "\"\"",
      "reflect": true,
      "description": "Currently selected option value."
    },
    {
      "name": "options",
      "type": "ThemeSwitcherOption[]",
      "required": false,
      "default": "[]",
      "description": "Array of { value, label, group? }; can also be supplied as a JSON attribute."
    }
  ],
  "events": [
    {
      "name": "ce-change",
      "detail": "{ value: string }",
      "bubbles": true,
      "composed": true,
      "description": "Fires when the user picks (or cycles to) a different option."
    }
  ],
  "slots": [],
