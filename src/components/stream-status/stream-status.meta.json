{
  "schemaVersion": 2,
  "tag": "ce-stream-status",
  "name": "Stream status",
  "className": "CeStreamStatus",
  "goal": "Streaming-connection state pill — idle / connecting / streaming / done / error — with optional token counter and tokens-per-second readout.",
  "description": "Compact inline pill that communicates LLM streaming connection state via a color-coded background, border, and animated dot. Optionally renders a formatted token count and a tokens-per-second readout alongside the state label. Sets role=status + aria-live=polite so assistive technology announces state changes.",
  "stability": "beta",
  "created": "2026-05-20",
  "updated": "2026-05-26",
  "props": [
    {
      "name": "state",
      "type": "CeStreamState",
      "required": false,
      "default": "\"idle\"",
      "attribute": "state",
      "reflect": true,
      "description": "Connection state; drives color, border, and pulse animation. One of idle | connecting | streaming | done | error."
    },
    {
      "name": "label",
      "type": "string",
      "required": false,
      "default": "\"\"",
      "attribute": "label",
      "reflect": false,
      "description": "Override label text. When empty, a state-default label is used (Idle / Connecting… / Streaming / Done / Error)."
    },
    {
      "name": "tokens",
      "type": "number | null",
      "required": false,
      "default": "null",
      "attribute": "tokens",
      "reflect": false,
      "description": "Optional token count. When set, rendered as a locale-formatted number followed by 'tokens'."
    },
    {
      "name": "tps",
      "type": "number | null",
      "required": false,
      "default": "null",
      "attribute": "tps",
      "reflect": false,
      "description": "Optional tokens-per-second. When set, rendered as an integer followed by 'tok/s', separated from the token count by a middle-dot."
    }
  ],
  "events": [],
  "slots": [
    {
      "name": "",
      "description": "Fully replaces the auto-generated label and counter content. When used, the host takes complete control of inner text."
    }
  ],
  "cssVariables": [
    {
      "name": "--ce-surface-2",
      "kind": "color",
      "source": "token",
      "description": "Neutral (idle) pill background."
    },
    {
      "name": "--ce-border",
      "kind": "color",
      "source": "token",
      "description": "Neutral (idle) pill border."
    },
    {
      "name": "--ce-radius-pill",
      "kind": "radius",
      "source": "token",
      "description": "Pill border-radius."
    },
    {
      "name": "--ce-inset-xs",
      "kind": "size",
      "source": "token",
      "description": "Vertical padding inside the pill."
    },
    {
      "name": "--ce-space-2",
      "kind": "size",
      "source": "token",
      "description": "Horizontal pill padding and gap between dot and label."
    },
    {
      "name": "--ce-text-xs",
      "kind": "font",
      "source": "token",
      "description": "Pill font size."
    },
    {
      "name": "--ce-font-sans",
      "kind": "font",
      "source": "token",
      "description": "Pill font family."
    },
    {
      "name": "--ce-text",
      "kind": "color",
      "source": "token",
      "description": "Pill label text color."
    },
    {
      "name": "--ce-muted",
      "kind": "color",
      "source": "token",
      "description": "Idle dot color and counter text color."
    },
    {
      "name": "--ce-line-snug",
