  "codeDependencies": [],
  "tagDependencies": [],
  "injects": [],
  "role": "leaf",
  "interchangeableWith": [
    {
      "tag": "ce-spinner",
      "scope": "loading"
    }
  ],
  "category": "ui",
  "tier": "brick",
  "tags": [
    "Chat surfaces",
    "status",
    "streaming"
  ],
  "a11y": {
    "role": "status",
    "notes": "On connectedCallback the host receives role='status' and aria-live='polite' (unless already set by the page). This causes assistive technology to announce state transitions politely without interrupting the current reading flow."
  },
  "contentModel": "block",
  "deterministic": true,
  "streamSafe": true,
  "streamingLifecycle": {
    "finalizesAt": "blockEnd"
  }
}
