      "description": "Label line-height."
    },
    {
      "name": "--ce-color-blue",
      "kind": "color",
      "source": "token",
      "description": "Dot color when state=connecting."
    },
    {
      "name": "--ce-color-blue-bg",
      "kind": "color",
      "source": "token",
      "description": "Pill background tint when state=connecting."
    },
    {
      "name": "--ce-color-blue-border",
      "kind": "color",
      "source": "token",
      "description": "Pill border when state=connecting."
    },
    {
      "name": "--ce-color-purple",
