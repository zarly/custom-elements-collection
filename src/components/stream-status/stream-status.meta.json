      "description": "Dot color when state=streaming."
    },
    {
      "name": "--ce-color-purple-bg",
      "kind": "color",
      "source": "token",
      "description": "Pill background tint when state=streaming."
    },
    {
      "name": "--ce-color-purple-border",
      "kind": "color",
      "source": "token",
      "description": "Pill border when state=streaming."
    },
    {
      "name": "--ce-color-green",
      "kind": "color",
      "source": "token",
      "description": "Dot color when state=done."
    },
    {
      "name": "--ce-color-green-bg",
      "kind": "color",
      "source": "token",
      "description": "Pill background tint when state=done."
    },
    {
      "name": "--ce-color-green-border",
      "kind": "color",
