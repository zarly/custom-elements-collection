    },
    {
      "name": "--ce-color-red-bg",
      "kind": "color",
      "source": "token",
      "description": "Pill background tint when state=error."
    },
    {
      "name": "--ce-color-red-border",
      "kind": "color",
      "source": "token",
      "description": "Pill border when state=error."
    }
  ],
  "globalDependencies": [
    {
      "api": "Intl.NumberFormat",
      "purpose": "Formats the token count with locale-appropriate thousands separators.",
      "writes": false
    }
  ],
  "sideEffects": [
    {
      "kind": "dom",
      "description": "Sets role='status' and aria-live='polite' on the host element during connectedCallback.",
      "reason": "Ensures assistive technology announces state changes without the consumer needing to add ARIA manually.",
      "guarded": true
    }
  ],
  "dependents": [],
  "dependencies": [],
  "related": [
    "ce-status-light",
