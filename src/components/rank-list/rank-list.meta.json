{
  "schemaVersion": 2,
  "tag": "ce-rank-list",
  "name": "Rank list",
  "className": "CeRankList",
  "goal": "Render a ranked list with computed position numbers, optional scores, and optional movement deltas.",
  "description": "Static-by-default ranking primitive for leaderboards, top-N reports, and ordered priorities. Position numbers are computed from list order (#1, #2, …) so authors don't renumber on reorder; an offset start attribute lets the list begin at any rank. Optional score column right-aligns numeric or string values; optional delta column shows ▲ / ▼ / — movement coloured by direction. By default the top three items are accented with medal colours (gold / silver / bronze); pass `flat` to disable. Accepts JSON items or slotted <li> children (CDR-005); in slot mode the rank is rendered as a counter prefix.",
  "stability": "stable",
  "created": "2026-05-20",
  "updated": "2026-05-26",
  "props": [
    {
      "name": "items",
      "type": "RankItem[]",
      "required": false,
      "default": "[]",
      "description": "JSON array of ranked entries ({label, hint?, score?, delta?}). When empty, slotted <li> children are used."
    },
    {
      "name": "start",
      "type": "number",
      "required": false,
      "default": "1",
      "description": "First rank number. Useful when continuing a list from a previous page."
    },
    {
      "name": "flat",
      "type": "boolean",
      "required": false,
      "default": "false",
      "reflect": true,
      "description": "Disable the top-3 medal accents; renders all ranks in a neutral pill."
    }
  ],
  "events": [],
  "slots": [
    {
      "name": "",
      "description": "Slotted <li> children for the slot-mode authoring path. The rank counter is rendered as a ::before prefix."
    }
  ],
