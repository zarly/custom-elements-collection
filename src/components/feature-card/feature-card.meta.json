{
  "schemaVersion": 1,
  "tag": "ce-feature-card",
  "name": "FeatureCard",
  "className": "CeFeatureCard",
  "goal": "Present a feature with an icon, title, body, and optional CTA button or link.",
  "description": "Marketing-style feature card. Top: tinted icon disk. Middle: title + slotted body. Bottom: optional CTA — rendered as an <a> when href is set, otherwise a <button> that emits ce-feature-cta. Six color tints adjust the icon disk.",
  "stability": "stable",
  "created": "2026-04-29",
  "updated": "2026-05-21",
  "props": [
    {
      "name": "icon",
      "type": "string",
      "required": false,
      "default": "\"\"",
      "description": "Emoji or short text glyph used as the icon."
    },
    {
      "name": "title",
      "type": "string",
      "required": false,
      "default": "\"\"",
      "description": "Card heading."
    },
    {
      "name": "cta",
      "type": "string",
      "required": false,
      "default": "\"\"",
      "description": "Call-to-action label. Empty = no CTA rendered."
    },
    {
      "name": "href",
      "type": "string",
      "required": false,
      "default": "\"\"",
      "description": "If set together with cta, renders as a link instead of a button."
    },
    {
      "name": "color",
      "type": "CecColor",
      "required": false,
      "default": "\"neutral\"",
      "reflect": true,
      "description": "Icon disk color tint."
    }
  ],
  "events": [
    {
      "name": "ce-feature-cta",
      "detail": "void",
      "bubbles": true,
      "composed": true,
      "description": "Fires when the button-form CTA is clicked (only when href is empty)."
    }
  ],
  "slots": [
    {
      "name": "",
      "description": "Body content between title and CTA."
    }
  ],
