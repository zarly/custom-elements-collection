{
  "schemaVersion": 1,
  "tag": "ce-radio-group",
  "name": "RadioGroup",
  "className": "CeRadioGroup",
  "goal": "Provide a single-select group control with classic, segmented, or card visual variants and full keyboard support.",
  "description": "Radio-group with three visual treatments: 'classic' (traditional radio circles), 'segmented' (joined-button group), and 'card' (option-as-card with optional hint line). Roving tabindex; arrow keys + Home/End move selection; Space/Enter activate. Options provided as a JSON array; per-option disabled state honored. Emits ce-change with { name, value }.",
  "stability": "experimental",
  "created": "2026-05-08",
  "updated": "2026-05-21",
  "props": [
    {
      "name": "name",
      "type": "string",
      "required": false,
      "default": "\"\"",
      "description": "Form-control name; echoed in ce-change detail."
    },
    {
      "name": "value",
      "type": "string",
      "required": false,
      "default": "\"\"",
      "description": "Currently selected option value. Empty means no selection."
    },
    {
      "name": "variant",
      "type": "\"classic\" | \"segmented\" | \"card\"",
      "required": false,
      "default": "\"classic\"",
      "reflect": true,
      "description": "Visual treatment. Invalid values fall back to 'classic'."
    },
    {
      "name": "vertical",
      "type": "boolean",
      "required": false,
      "default": "false",
      "reflect": true,
      "description": "Stack options vertically. Default for card variant when grid would otherwise wrap."
    },
    {
      "name": "disabled",
      "type": "boolean",
      "required": false,
      "default": "false",
      "reflect": true,
      "description": "Disable the entire group."
    },
    {
      "name": "options",
      "type": "RadioOption[]",
      "required": false,
      "default": "[]",
      "description": "Array of { value, label, hint?, disabled? }. Settable as a JS property or as a JSON-encoded attribute."
    }
  ],
  "events": [
    {
      "name": "ce-change",
      "detail": "{ name: string, value: string }",
      "bubbles": true,
      "composed": true,
      "description": "Fires when the user picks a different option."
    }
  ],
  "slots": [],
  "cssVariables": [
    {
      "name": "--ce-color-blue",
      "kind": "color",
      "source": "token",
      "description": "Selected indicator + segmented-active background."
    },
    {
      "name": "--ce-text",
      "kind": "color",
      "source": "token",
      "description": "Default label color."
    },
    {
      "name": "--ce-text-inverse",
      "kind": "color",
      "source": "token",
      "description": "Segmented-active label color (defaults to white)."
    },
    {
