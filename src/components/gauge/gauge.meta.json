  "a11y": {
    "role": "meter",
    "notes": "SVG carries role=meter with aria-valuemin / aria-valuemax / aria-valuenow. The aria-label reads 'label: value of max (target N)' so screen readers announce the target alongside the value. A <title> child of the SVG drives the native browser tooltip on hover; the target tick has its own <title> with 'Target: N'."
  }
}
