{
  "schemaVersion": 1,
  "tag": "ce-gauge",
  "name": "Gauge",
  "className": "CeGauge",
  "goal": "Render a semicircle dial showing a single value within min..max with optional target tick.",
  "description": "Half-circle meter that visualises one numeric value relative to a range, with a fill arc, the value displayed inside, and an optional target tick mark to indicate a goal threshold. Hovering the gauge surfaces a native browser tooltip with the value, range, and target; the tick itself shows a 'Target: N' tooltip on hover. Pure inline SVG; clamps values outside the range so it stays within the dial.",
  "stability": "stable",
  "created": "2026-05-05",
  "updated": "2026-05-21",
  "props": [
    {
      "name": "value",
      "type": "number",
      "required": false,
      "default": "0",
      "description": "Current value."
    },
    {
      "name": "min",
      "type": "number",
      "required": false,
      "default": "0",
      "description": "Lower bound."
    },
    {
      "name": "max",
      "type": "number",
      "required": false,
      "default": "100",
      "description": "Upper bound."
    },
    {
      "name": "target",
      "type": "number | null",
      "required": false,
      "default": "null",
      "description": "Optional target value rendered as a tick mark. Surfaces 'Target: N' on hover."
    },
    {
      "name": "color",
      "type": "CecColor",
      "required": false,
      "default": "\"blue\"",
      "reflect": true,
      "description": "Fill color token."
    },
    {
      "name": "label",
      "type": "string",
      "required": false,
      "default": "\"\"",
      "description": "Small label rendered under the value."
    },
    {
      "name": "size",
      "type": "number",
      "required": false,
      "default": "140",
      "description": "SVG square size in CSS px."
    }
  ],
  "events": [],
  "slots": [],
  "cssVariables": [
