  "tag": "ce-mark",
  "name": "Mark",
  "className": "CeMark",
  "goal": "Highlight a span of inline text with a themed color tint.",
  "description": "Inline highlight primitive used for search-result hits, AI-mentioned entities, or 'this changed' emphasis. Seven CecColor tints (amber default), two emphasis weights (subtle uses a tinted background, strong uses a saturated fill with inverted text). Uses box-decoration-break:clone so the highlight wraps cleanly across line breaks.",
  "stability": "stable",
  "created": "2026-05-21",
  "updated": "2026-05-26",
  "props": [
    {
      "name": "color",
      "type": "CecColor | null",
      "required": false,
      "default": "null",
      "reflect": true,
      "description": "Highlight color (amber default when null)."
    },
    {
      "name": "weight",
      "type": "\"subtle\" | \"strong\"",
      "required": false,
      "default": "\"subtle\"",
      "reflect": true,
      "description": "Emphasis — subtle uses a tinted background; strong uses a saturated fill with inverted text."
    }
  ],
