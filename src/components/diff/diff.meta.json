{
  "schemaVersion": 2,
  "tag": "ce-diff",
  "name": "Diff",
  "className": "CeDiff",
  "goal": "Render a line-level diff between two text blobs in unified or split layout.",
  "description": "Compact LCS-based diff viewer for code review surfaces and PR comments. Choose unified (single column with +/−/ space markers) or split (two columns side-by-side). Header surfaces the language label and the add/delete summary. The LCS algorithm runs in O(n × m) so it's intended for short-to-medium diffs (a few hundred lines).",
  "stability": "stable",
  "created": "2026-05-05",
  "updated": "2026-05-26",
  "props": [
    {
      "name": "beforeText",
      "type": "string",
      "required": false,
      "default": "\"\"",
      "attribute": "before",
      "description": "Original text (attribute: before). Falls back to slot=before."
    },
    {
      "name": "afterText",
      "type": "string",
      "required": false,
      "default": "\"\"",
      "attribute": "after",
      "description": "Changed text (attribute: after). Falls back to slot=after."
    },
    {
      "name": "layout",
      "type": "\"unified\" | \"split\"",
      "required": false,
      "default": "\"unified\"",
      "reflect": true,
      "description": "Diff layout."
    },
    {
      "name": "language",
      "type": "string",
      "required": false,
      "default": "\"\"",
      "description": "Informational language tag."
    }
  ],
  "events": [],
  "slots": [
    {
      "name": "before",
      "description": "Original text source (alt to before attribute).",
      "acceptShapes": [
        "string"
      ]
    },
    {
      "name": "after",
      "description": "Changed text source (alt to after attribute).",
      "acceptShapes": [
        "string"
      ]
    }
  ],
