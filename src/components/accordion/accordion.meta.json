{
  "schemaVersion": 2,
  "tag": "ce-accordion",
  "name": "Accordion",
  "className": "CeAccordion",
  "goal": "Render a grouped list of disclosure rows where any (or in single mode, exactly one) row may be open at a time.",
  "description": "Multi-disclosure companion to ce-details. Accepts JSON items ({summary, body?, count?, open?, id?}) or slotted <details> / <ce-details> children (CDR-005). Static-by-default — items render with their initial open state and toggle via native <details>; the component tracks open state internally for ergonomic event payloads. When `single` is set, opening one row closes all others (radio-style FAQ pattern). Emits ce-accordion-change with the array of currently-open ids.",
  "stability": "stable",
  "created": "2026-05-20",
  "updated": "2026-05-26",
  "props": [
    {
      "name": "items",
      "type": "AccordionItem[]",
      "required": false,
      "default": "[]",
      "description": "JSON array of disclosure rows ({id?, summary, body?, count?, open?}). When empty, slotted children are used."
    },
    {
      "name": "single",
      "type": "boolean",
      "required": false,
      "default": "false",
      "reflect": true,
      "description": "Only one row may be open at a time; opening another closes the rest."
    }
  ],
  "events": [
    {
      "name": "ce-accordion-change",
      "detail": "{ openIds: string[] }",
      "bubbles": true,
      "composed": true,
      "description": "Fired whenever an item opens or closes. Detail.openIds is the full set of currently-open ids (or array indices when items have no id)."
    }
  ],
  "slots": [
    {
      "name": "",
      "description": "Slotted <details> / <ce-details> children for the slot-mode authoring path."
    }
  ],
