{
  "schemaVersion": 1,
  "tag": "ce-section",
  "name": "Section",
  "className": "CeSection",
  "goal": "Group page content under a titled header with optional number badge, lede, and right-aligned count chip.",
  "description": "Titled content section. Renders a header row containing an optional circular number badge, a heading, and an optional count chip on the right; underneath the row sits an optional lede paragraph and the default body slot. Used to break long pages into numbered chapters.",
  "stability": "stable",
  "props": [
    {
      "name": "title",
      "type": "string",
      "required": false,
      "default": "\"\"",
      "description": "Section heading. Use the title slot for custom markup."
    },
    {
      "name": "lede",
      "type": "string",
      "required": false,
      "default": "\"\"",
      "description": "Optional subtitle below the heading."
    },
    {
      "name": "number",
      "type": "string",
      "required": false,
      "default": "\"\"",
      "description": "Optional number / glyph for the badge to the left of the heading."
    },
    {
      "name": "countLabel",
      "type": "string",
      "required": false,
      "default": "\"\"",
      "attribute": "count-label",
      "description": "Right-aligned count chip text (e.g. '28 files · 7 locations')."
    }
  ],
  "events": [],
  "slots": [
    {
      "name": "title",
      "description": "Custom heading markup; overrides the title attribute."
    },
