{
  "schemaVersion": 2,
  "tag": "ce-pros-cons",
  "name": "Pros & cons",
  "className": "CeProsCons",
  "goal": "Render explicit pros vs cons in a two-column block with semantic colour accents.",
  "description": "Decision-analysis primitive that replaces the ad-hoc 'ce-compare for pros/cons' workaround surfaced in audit. Two columns: left=pros (green accent, ✓ markers), right=cons (red accent, ✗ markers). Each side accepts either a JSON array of strings (CDR-005 JSON mode) or slotted <li> / arbitrary children (slot mode), and the two modes may be mixed (JSON pros + slotted cons). Headers default to 'Pros' / 'Cons' and accept attribute overrides for localised or domain-specific phrasing ('Benefits' / 'Risks', 'Plusy' / 'Minusy', etc.). Stacks to a single column below ~540 px.",
  "stability": "stable",
  "created": "2026-05-20",
  "updated": "2026-05-26",
  "props": [
    {
      "name": "pros",
      "type": "string[]",
      "required": false,
      "default": "[]",
      "description": "JSON array of pros (strings). When empty, the 'pros' named slot is used."
    },
    {
      "name": "cons",
      "type": "string[]",
      "required": false,
      "default": "[]",
      "description": "JSON array of cons (strings). When empty, the 'cons' named slot is used."
    },
    {
      "name": "prosLabel",
      "type": "string",
      "required": false,
      "default": "\"Pros\"",
      "attribute": "pros-label",
      "description": "Left-column header."
    },
    {
      "name": "consLabel",
      "type": "string",
      "required": false,
      "default": "\"Cons\"",
      "attribute": "cons-label",
      "description": "Right-column header."
    }
  ],
  "events": [],
  "slots": [
    {
      "name": "pros",
      "description": "List items (or arbitrary nodes) for the pros column. Used when the pros array is empty."
    },
    {
      "name": "cons",
      "description": "List items (or arbitrary nodes) for the cons column. Used when the cons array is empty."
    }
  ],
  "cssVariables": [
