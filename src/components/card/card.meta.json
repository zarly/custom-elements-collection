      "description": "Title text color."
    },
    {
      "name": "--ce-text-sm",
      "kind": "size",
      "source": "token",
      "description": "Footer font size."
    },
    {
      "name": "--ce-muted",
      "kind": "color",
      "source": "token",
      "description": "Footer text color."
    }
  ],
  "globalDependencies": [],
  "sideEffects": [],
  "dependents": [],
  "dependencies": [],
  "related": [
    "ce-grid"
  ],
  "requiredParent": [],
  "childPolicy": "any",
  "codeDependencies": [],
  "tagDependencies": [],
  "injects": [],
  "role": "container",
  "interchangeableWith": [],
  "category": "ui",
  "tier": "brick",
  "tags": [
    "Layout & primitives",
    "container"
  ],
  "a11y": {
    "role": "button (when clickable)",
    "notes": "When clickable=true the host gets role=\"button\" and tabindex=\"0\"; Enter and Space both emit ce-card-activate. When toggled off, role/tabindex are removed."
  },
  "contentModel": "block",
  "deterministic": true,
  "streamSafe": true,
  "streamingLifecycle": {
    "finalizesAt": "blockEnd"
  }
}
