{
  "schemaVersion": 1,
  "tag": "ce-kpi",
  "name": "Kpi",
  "className": "CeKpi",
  "goal": "Display a single big-number stat with label, optional trend indicator, and semantic color tint.",
  "description": "Single-stat KPI block — large value, small uppercase label, and optional inline trend (e.g. '+12%') that auto-colors based on its leading sign (+ green, - red, otherwise neutral). Used inside <ce-hero slot=\"stats\"> or in any grid row.",
  "stability": "stable",
  "props": [
    {
      "name": "value",
      "type": "string",
      "required": false,
      "default": "\"\"",
      "description": "Primary figure shown large."
    },
    {
      "name": "label",
      "type": "string",
      "required": false,
      "default": "\"\"",
      "description": "Uppercase label below the value."
    },
    {
      "name": "color",
      "type": "CecColor",
      "required": false,
      "default": "\"neutral\"",
      "reflect": true,
      "description": "Tint for the value text (neutral / green / red / amber / blue / purple / cyan)."
    },
    {
      "name": "trend",
      "type": "string",
      "required": false,
      "default": "\"\"",
      "description": "Trend indicator. Color flag derives from leading + / - / other."
    }
  ],
