{
  "schemaVersion": 1,
  "tag": "ce-verdict",
  "name": "Verdict",
  "className": "CeVerdict",
  "goal": "Show a final-decision banner — go / no-go / mixed / info — with an icon, title, and detail line.",
  "description": "Decision banner with icon, title, and detail. Four semantic types tint the border, background, icon, and title color. Default icons are ✓ ✗ ⚠ ℹ; consumers can override via the icon attribute or supply custom title markup via the title slot.",
  "stability": "stable",
  "created": "2026-04-29",
  "updated": "2026-05-21",
  "props": [
    {
      "name": "type",
      "type": "VerdictType",
      "required": false,
      "default": "\"info\"",
      "reflect": true,
      "description": "go (green) / no-go (red) / mixed (amber) / info (blue)."
    },
    {
      "name": "title",
      "type": "string",
      "required": false,
      "default": "\"\"",
      "description": "Short verdict line."
    },
    {
      "name": "detail",
      "type": "string",
      "required": false,
      "default": "\"\"",
      "description": "Supporting sentence used as default-slot fallback."
    },
    {
      "name": "icon",
      "type": "string",
      "required": false,
      "default": "\"\"",
      "description": "Override icon character; empty string uses the default for the type."
    },
    {
      "name": "inline",
      "type": "boolean",
      "required": false,
      "default": "false",
      "reflect": true,
      "description": "Compact pill layout (per-instance override). Default slot becomes the label; empty slot falls back to the type-default label (Go / No-go / Mixed / Info). Pairs with --ce-verdict-layout for document-wide control via @container style()."
    }
  ],
  "events": [],
  "slots": [
    {
      "name": "title",
      "description": "Custom title markup; overrides the title attribute (banner mode only)."
    },
    {
      "name": "",
      "description": "Banner mode: detail content; falls back to the detail attribute. Inline mode: label text; falls back to the type-default label (Go / No-go / Mixed / Info)."
    }
  ],
