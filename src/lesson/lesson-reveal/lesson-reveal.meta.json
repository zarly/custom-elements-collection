{
  "schemaVersion": 1,
  "tag": "lesson-reveal",
  "name": "LessonReveal",
  "className": "LessonReveal",
  "goal": "Flashcard that displays a front (question/term) and reveals the back (answer) on click.",
  "description": "Single-card flashcard widget. Displays front-label + front text with a 'Click to reveal' hint. On click, flips to show back-label (green) + back text + reset hint. Fires lesson-reveal-flip on each flip. reset() returns to front state. Entire card is clickable.",
  "stability": "stable",
  "created": "2026-05-07",
  "updated": "2026-05-21",
  "props": [
    {
      "name": "front",
      "type": "string",
      "required": false,
      "default": "\"\"",
      "description": "Question or term text shown on the front."
    },
    {
      "name": "back",
      "type": "string",
      "required": false,
      "default": "\"\"",
      "description": "Answer or definition text revealed on flip."
    },
    {
      "name": "front-label",
      "type": "string",
      "required": false,
      "default": "\"Question\"",
      "description": "Label shown above the front text."
    },
    {
      "name": "back-label",
      "type": "string",
      "required": false,
      "default": "\"Answer\"",
      "description": "Label shown above the back text after flip."
    }
  ],
  "events": [
    {
      "name": "lesson-reveal-flip",
      "detail": "{ flipped: boolean }",
      "bubbles": true,
      "composed": true,
      "description": "Fires on every flip. detail.flipped is true when showing back, false when back at front."
    }
  ],
  "methods": [
    {
      "name": "reset",
      "signature": "() => void",
      "description": "Returns the card to the front (unflipped) state."
    }
  ],
  "slots": [],
