{
  "schemaVersion": 2,
  "tag": "lesson-myth",
  "name": "LessonMyth",
  "className": "LessonMyth",
  "goal": "Present a common misconception, then reveal its correction on click — the myth-busting pattern.",
  "description": "Shows a red-tinted myth card with a '✗ Myth' badge and the false belief. On click, flips to a green-tinted truth card with '✓ Truth' badge and the correct statement. Optional explanation shown below truth. Fires lesson-myth-reveal once on first reveal. reset() returns to myth view.",
  "stability": "stable",
  "created": "2026-05-07",
  "updated": "2026-05-26",
  "props": [
    {
      "name": "myth",
      "type": "string",
      "required": false,
      "default": "\"\"",
      "description": "The false belief or misconception to display initially."
    },
    {
      "name": "truth",
      "type": "string",
      "required": false,
      "default": "\"\"",
      "description": "The correct statement revealed on click."
    },
    {
      "name": "explanation",
      "type": "string",
      "required": false,
      "default": "\"\"",
      "description": "Optional longer explanation shown below the truth after reveal."
    }
  ],
  "events": [
    {
      "name": "lesson-myth-reveal",
      "detail": "{}",
      "bubbles": true,
      "composed": true,
      "description": "Fires exactly once when the truth is first revealed."
    }
  ],
  "methods": [
    {
      "name": "reset",
      "signature": "() => void",
      "description": "Returns the card to the myth view."
    }
  ],
