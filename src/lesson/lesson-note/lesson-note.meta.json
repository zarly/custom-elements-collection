{
  "schemaVersion": 2,
  "tag": "lesson-note",
  "name": "LessonNote",
  "className": "LessonNote",
  "goal": "Callout aside for lesson content — tip, info, key point, warning, or danger.",
  "description": "Renders a left-bordered, tinted callout block with an auto-selected icon based on type. The icon can be overridden. Five types supported: tip (blue), info (cyan), key (amber), warning (amber), danger (red).",
  "stability": "stable",
  "created": "2026-05-07",
  "updated": "2026-05-26",
  "props": [
    {
      "name": "type",
      "type": "string",
      "required": false,
      "default": "\"info\"",
      "reflect": true,
      "description": "Callout type. One of: tip | info | key | warning | danger."
    },
    {
      "name": "icon",
      "type": "string",
      "required": false,
      "default": "\"\"",
      "description": "Override the auto-selected icon emoji."
    }
  ],
  "events": [],
  "methods": [],
  "slots": [
    {
      "name": "",
      "description": "Body content of the callout."
    }
  ],
