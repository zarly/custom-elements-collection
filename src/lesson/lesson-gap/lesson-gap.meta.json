{
  "schemaVersion": 1,
  "tag": "lesson-gap",
  "name": "LessonGap",
  "className": "LessonGap",
  "goal": "Run a fill-in-the-blank exercise with multiple-choice options, instant feedback, and a public reset() method.",
  "description": "Fill-in-the-blank exercise. Splits the prompt at the first '___' marker and renders the gap as a colored span; below sit the options as buttons. After the user picks, the chosen button colors green or red, the gap fills with the correct answer when correct, and a feedback strip shows the explanation. lesson-gap-answer fires once per exercise.",
  "stability": "stable",
  "props": [
    {
      "name": "prompt",
      "type": "string",
      "required": false,
      "default": "\"\"",
      "description": "Sentence containing one '___' placeholder. If empty, renders the default slot instead."
    },
    {
      "name": "options",
      "type": "string[]",
      "required": false,
      "default": "[]",
      "description": "Answer choices."
    },
    {
      "name": "correct",
      "type": "string",
      "required": false,
      "default": "\"\"",
      "description": "The correct option (must match a member of options)."
    },
    {
      "name": "explanation",
      "type": "string",
      "required": false,
      "default": "\"\"",
      "description": "Shown after the user picks."
    }
  ],
  "events": [
    {
      "name": "lesson-gap-answer",
      "detail": "{ value: string; correct: boolean }",
      "bubbles": true,
      "composed": true,
      "description": "Fires once when the user picks an option; detail.correct indicates whether the pick matched."
    }
  ],
  "methods": [
    {
      "name": "reset",
      "signature": "() => void",
      "description": "Clears the picked state and re-enables the buttons."
    }
  ],
  "slots": [
    {
      "name": "",
      "description": "Used as the prompt fallback when the prompt attribute is empty."
    }
  ],
