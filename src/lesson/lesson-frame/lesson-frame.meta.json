{
  "schemaVersion": 1,
  "tag": "lesson-frame",
  "name": "LessonFrame",
  "className": "LessonFrame",
  "goal": "Wrap a lesson page with a fixed top progress bar and a centered, padded content column.",
  "description": "Top-level lesson shell. Renders a fixed 4px progress bar at the top of the viewport (driven by the progress prop), a centered title + meta row, and a content column with a max-width of 880px. Used as the outermost element on a lesson page.",
  "stability": "stable",
  "props": [
    {
      "name": "progress",
      "type": "number",
      "required": false,
      "default": "0",
      "description": "Completion percent in [0, 100]."
    },
    {
      "name": "title",
      "type": "string",
      "required": false,
      "default": "\"\"",
      "description": "Lesson title shown in the centered header."
    },
    {
      "name": "meta",
      "type": "string",
      "required": false,
      "default": "\"\"",
      "description": "Short meta line (difficulty · time · impact) under the title."
    }
  ],
  "events": [],
  "slots": [
    {
      "name": "header",
      "description": "Extra header content (chips, tags) below the meta line."
    },
