{
  "schemaVersion": 2,
  "tag": "lesson-vocab",
  "name": "LessonVocab",
  "className": "LessonVocab",
  "goal": "Vocabulary term card with all metadata a learner needs: term, phonetic, part of speech, definition, example usage.",
  "description": "Fully prop-driven vocabulary card. Shows the term in large bold text, optional phonetic in monospace, optional pos badge (amber), optional level badge (muted). Definition and example sentence below. Suitable for language learning and technical terminology. No slots — all content is prop-driven for LLM-friendly markup.",
  "stability": "stable",
  "created": "2026-05-07",
  "updated": "2026-05-26",
  "props": [
    {
      "name": "term",
      "type": "string",
      "required": false,
      "default": "\"\"",
      "description": "The word or concept to define."
    },
    {
      "name": "phonetic",
      "type": "string",
      "required": false,
      "default": "\"\"",
      "description": "IPA or phonetic transcription."
    },
    {
      "name": "pos",
      "type": "string",
      "required": false,
      "default": "\"\"",
      "description": "Part of speech: noun, verb, adj, adv, abbr, etc."
    },
    {
      "name": "definition",
      "type": "string",
      "required": false,
      "default": "\"\"",
      "description": "The meaning or explanation."
    },
    {
      "name": "example",
      "type": "string",
      "required": false,
      "default": "\"\"",
      "description": "Example sentence shown in italics."
    },
    {
      "name": "level",
      "type": "string",
      "required": false,
      "default": "\"\"",
      "description": "Proficiency label: A1, B2, advanced, etc."
    }
  ],
