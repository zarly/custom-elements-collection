{
  "schemaVersion": 1,
  "tag": "lesson-quiz",
  "name": "LessonQuiz",
  "className": "LessonQuiz",
  "goal": "Run a single-question multiple-choice quiz with instant feedback, an explanation reveal, and a reset() method.",
  "description": "Single-question multiple-choice quiz. Renders a question and a vertical list of options; clicking an option marks it green if correct or red if wrong (and outlines the correct one), shows the explanation below, and disables the rest. lesson-quiz-answer fires once per question.",
  "stability": "stable",
  "created": "2026-04-29",
  "updated": "2026-05-21",
  "props": [
    {
      "name": "question",
      "type": "string",
      "required": false,
      "default": "\"\"",
      "description": "Question text."
    },
    {
      "name": "options",
      "type": "string[]",
      "required": false,
      "default": "[]",
      "description": "Answer choices."
    },
    {
      "name": "correct",
      "type": "number",
      "required": false,
      "default": "0",
      "description": "Index of the correct option in options."
    },
    {
      "name": "explanation",
      "type": "string",
      "required": false,
      "default": "\"\"",
      "description": "Shown after the user picks."
    }
  ],
  "events": [
    {
      "name": "lesson-quiz-answer",
      "detail": "{ index: number; correct: boolean }",
      "bubbles": true,
      "composed": true,
      "description": "Fires once when the user picks; detail.correct indicates whether the pick matched correct."
    }
  ],
  "methods": [
    {
      "name": "reset",
      "signature": "() => void",
      "description": "Clears the picked state so the quiz can be retaken."
    }
  ],
  "slots": [],
